---
// src/components/Novedades.astro
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";

type Novedad = CollectionEntry<"novedades">;

const todasLasNovedades = await getCollection("novedades");
todasLasNovedades.sort(
  (a: Novedad, b: Novedad) => b.data.date.valueOf() - a.data.date.valueOf(),
);

// 👇 TRUCO: Solo mostramos las últimas 3 actualizaciones en la landing
const ultimasNovedades = todasLasNovedades.slice(0, 3);
---

<section
  id="novedades"
  class="py-20 md:py-32 bg-white relative overflow-hidden scroll-mt-20"
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div class="mb-16 md:mb-24 text-center" data-animate-trigger>
      <div
        class="opacity-0 translate-y-10 transition-all duration-700 ease-out animation-target"
      >
        <h2
          class="font-lobster text-5xl md:text-7xl text-yapaso-dark leading-tight tracking-wide drop-shadow-sm"
        >
          Historial de <br class="hidden sm:block" />
          <span
            class="inline-block bg-yapaso-yellow px-4 sm:px-6 py-2 transform -rotate-2 rounded-[20px] sm:rounded-[30px] border-[3px] sm:border-4 border-yapaso-dark shadow-[4px_4px_0px_0px_#1A1A1A] sm:shadow-[6px_6px_0px_0px_#1A1A1A] mt-2 sm:mt-4"
          >
            Novedades
          </span>
        </h2>
        <p
          class="font-sans mt-8 sm:mt-10 text-lg sm:text-xl md:text-2xl text-yapaso-dark font-medium max-w-2xl mx-auto leading-relaxed px-2"
        >
          Enterate de todas las mejoras y nuevas funciones que le vamos sumando
          a Ya Paso.
        </p>
      </div>
    </div>

    <div
      class="space-y-12 md:space-y-24 relative before:absolute before:inset-0 before:left-6 before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-1.5 before:bg-yapaso-dark before:rounded-full"
    >
      {
        ultimasNovedades.map(async (novedad: Novedad) => {
          const { Content } = await render(novedad);

          return (
            <article
              class="relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group is-active"
              data-animate-trigger
            >
              <div class="absolute left-6 md:left-1/2 -translate-x-1/2 flex items-center justify-center w-10 h-10 sm:w-12 sm:h-12 rounded-full border-[3px] sm:border-4 border-yapaso-dark bg-yapaso-yellow z-10 shadow-[4px_4px_0px_0px_#1A1A1A] group-hover:scale-110 transition-transform duration-300">
                <span class="w-2.5 h-2.5 sm:w-3 sm:h-3 bg-yapaso-dark rounded-full" />
              </div>

              <div class="w-[calc(100%-4rem)] sm:w-[calc(100%-5rem)] ml-auto md:ml-0 md:w-[calc(50%-4rem)] opacity-0 translate-y-10 transition-all duration-700 ease-out animation-target">
                <div class="bg-white p-6 sm:p-8 md:p-10 rounded-[30px] sm:rounded-[40px] border-[3px] sm:border-4 border-yapaso-dark shadow-[6px_6px_0px_0px_#1A1A1A] md:shadow-[8px_8px_0px_0px_#1A1A1A] hover:-translate-y-1 hover:shadow-[8px_8px_0px_0px_#1A1A1A] md:hover:shadow-[12px_12px_0px_0px_#1A1A1A] transition-all">
                  <div class="flex flex-wrap items-center gap-3 sm:gap-4 mb-4 sm:mb-6">
                    <span class="font-sans font-black bg-yapaso-dark text-yapaso-yellow px-3 sm:px-4 py-1 sm:py-1.5 rounded-lg sm:rounded-xl text-xs sm:text-sm tracking-widest uppercase border-2 border-yapaso-dark">
                      {novedad.data.version}
                    </span>
                    <time class="font-sans text-sm sm:text-base font-bold text-gray-500">
                      {novedad.data.date.toLocaleDateString("es-AR", {
                        year: "numeric",
                        month: "long",
                        day: "numeric",
                      })}
                    </time>
                  </div>

                  <h3 class="font-sans font-black text-2xl sm:text-3xl md:text-4xl text-yapaso-dark mb-4 sm:mb-6 leading-tight">
                    {novedad.data.title}
                  </h3>

                  <div class="prose prose-base sm:prose-lg prose-p:font-sans prose-p:font-medium prose-p:text-gray-600 prose-p:leading-relaxed prose-li:font-sans prose-li:font-medium prose-li:text-gray-600 prose-strong:text-yapaso-dark prose-strong:font-black max-w-none marker:text-yapaso-yellow">
                    <Content />
                  </div>
                </div>
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</section>
