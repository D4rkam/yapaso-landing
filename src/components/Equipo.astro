---
// src/components/Equipo.astro

// Datos de ejemplo para el equipo.
const equipo = [
  {
    nombre: "Thomas",
    rol: "Lead Developer & Cofounder",
    desc: "Estudiante de Ing. en Sistemas. Apasionado por la arquitectura backend con Python, FastAPI y AWS. Encargado de que la app vuele.",
    iniciales: "TH",
    color: "bg-yapaso-dark",
  },
  {
    nombre: "Socio / Diseñador",
    rol: "UX/UI Designer",
    desc: "El cerebro detrás de las interfaces limpias y la experiencia de usuario sin fricciones en el buffet.",
    iniciales: "UX",
    color: "bg-yapaso-yellow",
  },
  {
    nombre: "Socio / Frontend",
    rol: "Mobile Developer",
    desc: "Especialista en desarrollo móvil, asegurando que la app funcione perfecto en cualquier celular Android o iOS.",
    iniciales: "FE",
    color: "bg-blue-600",
  },
];
---

<section id="equipo" class="py-16 md:py-24 bg-gray-50 border-y border-gray-100">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center mb-16">
      <span
        class="bg-[#E5F5D0] px-4 py-1.5 rounded-xl text-sm font-bold text-yapaso-dark uppercase tracking-wider"
      >
        Team
      </span>
      <h2 class="text-3xl md:text-4xl font-extrabold text-yapaso-dark mt-4">
        Conocé a los creadores
      </h2>
      <p class="text-gray-600 mt-4 text-lg">
        Estudiantes de la facultad, desarrollando soluciones para estudiantes.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        equipo.map((miembro) => (
          <article class="bg-white border border-gray-200 rounded-3xl overflow-hidden hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
            <div class="bg-[#E5F5D0] h-24 flex items-end px-6 relative">
              <div
                class={`w-20 h-20 ${miembro.color} rounded-2xl absolute -bottom-10 border-4 border-white flex items-center justify-center text-white text-2xl font-bold shadow-sm`}
              >
                {miembro.iniciales}
              </div>
            </div>

            <div class="p-6 pt-14">
              <h3 class="font-bold text-2xl text-yapaso-dark">
                {miembro.nombre}
              </h3>
              <p class="text-sm text-yapaso-dark font-bold mb-4 uppercase tracking-wide opacity-60">
                {miembro.rol}
              </p>
              <p class="text-gray-600 leading-relaxed">{miembro.desc}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
