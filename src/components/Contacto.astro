---
// src/components/Contacto.astro
---

<section id="contacto" class="py-24 bg-white relative overflow-hidden">
  <div class="max-w-4xl mx-auto px-6 relative z-10">
    <div class="flex flex-col items-center mb-16">
      <h2
        class="font-lobster text-6xl text-yapaso-dark rotate-[-2deg] bg-yapaso-yellow px-8 py-4 rounded-[20px] shadow-xl"
      >
        Contactanos
      </h2>
      <p class="font-sans text-xl mt-6 text-center text-gray-700">
        ¿Tenés dudas? Escribinos y te respondemos al toque.
      </p>
    </div>

    <form
      id="form-contacto"
      class="bg-white p-8 md:p-12 rounded-[40px] shadow-[0_30px_60px_rgba(0,0,0,0.08)] border border-gray-100 flex flex-col gap-8 relative group/form"
    >
      <div class="relative flex flex-col gap-2 group">
        <input
          type="text"
          name="nombre"
          placeholder="Tu Nombre"
          required
          pattern="[A-Za-z ]{3,}"
          class="peer font-sans w-full p-5 bg-white rounded-2xl border-2 border-gray-100 focus:border-yapaso-yellow focus:ring-4 focus:ring-yapaso-yellow/20 outline-none text-lg transition-all shadow-sm placeholder:text-gray-400"
        />
        <span
          class="absolute -right-4 -top-4 bg-yapaso-dark text-white text-xs font-bold px-3 py-1.5 rounded-lg opacity-0 peer-[:not(:placeholder-shown):invalid]:opacity-100 transition-opacity pointer-events-none rotate-6 z-20"
        >
          ¿Cómo te llamás? 🤔
        </span>
      </div>

      <div class="relative flex flex-col gap-2 group">
        <input
          type="email"
          name="email"
          placeholder="Tu Email"
          required
          class="peer font-sans w-full p-5 bg-white rounded-2xl border-2 border-gray-100 focus:border-yapaso-yellow focus:ring-4 focus:ring-yapaso-yellow/20 outline-none text-lg transition-all shadow-sm placeholder:text-gray-400"
        />
        <span
          class="absolute -right-4 -top-4 bg-yapaso-dark text-white text-xs font-bold px-3 py-1.5 rounded-lg opacity-0 peer-[:not(:placeholder-shown):invalid]:opacity-100 transition-opacity pointer-events-none -rotate-6 z-20"
        >
          Ese email no va che... 📧
        </span>
      </div>

      <div class="relative flex flex-col gap-2 group">
        <textarea
          name="mensaje"
          rows="4"
          placeholder="Tu Consulta"
          required
          minlength="10"
          class="peer font-sans w-full p-5 bg-white rounded-2xl border-2 border-gray-100 focus:border-yapaso-yellow focus:ring-4 focus:ring-yapaso-yellow/20 outline-none text-lg resize-none transition-all shadow-sm placeholder:text-gray-400"
        ></textarea>
        <span
          class="absolute -right-4 -top-4 bg-yapaso-dark text-white text-xs font-bold px-3 py-1.5 rounded-lg opacity-0 peer-[:not(:placeholder-shown):invalid]:opacity-100 transition-opacity pointer-events-none rotate-3 z-20"
        >
          Contanos un poco más ✍️
        </span>
      </div>

      <button
        type="submit"
        id="btn-submit"
        class="font-lobster text-3xl bg-white text-yapaso-dark py-6 rounded-xl border-2 border-yapaso-dark
         shadow-[4px_4px_0px_0px_rgba(26,26,26,1)] transition-all
         hover:bg-yapaso-yellow
         active:shadow-none active:translate-x-[2px] active:translate-y-[2px]
         disabled:opacity-30 disabled:grayscale disabled:cursor-not-allowed disabled:shadow-none
         disabled:active:translate-x-0 disabled:active:translate-y-0"
      >
        Enviar Mensaje
      </button>
    </form>
  </div>
</section>

<div
  id="toast-container"
  class="fixed bottom-10 left-1/2 -translate-x-1/2 z-[100] pointer-events-none transition-all duration-500 translate-y-20 opacity-0"
>
  <div
    id="toast-card"
    class="border-4 border-yapaso-dark px-6 py-4 flex items-center gap-4 shadow-[8px_8px_0px_0px_rgba(26,26,26,1)] min-w-[320px]"
  >
    <span id="toast-emoji" class="text-3xl"></span>
    <p id="toast-message" class="font-sans font-bold text-lg text-yapaso-dark">
    </p>
  </div>
</div>

<script>
  const form = document.getElementById("form-contacto") as HTMLFormElement;
  const btn = document.getElementById("btn-submit") as HTMLButtonElement;
  const inputs = form?.querySelectorAll("input, textarea");

  // Elementos del Toast
  const toastContainer = document.getElementById("toast-container");
  const toastCard = document.getElementById("toast-card");
  const toastMessage = document.getElementById("toast-message");
  const toastEmoji = document.getElementById("toast-emoji");

  const showToast = (msg: string, type: "success" | "error" = "success") => {
    if (!toastContainer || !toastCard || !toastMessage || !toastEmoji) return;

    toastMessage.innerText = msg;

    // Estilo según el tipo
    if (type === "success") {
      toastCard.style.backgroundColor = "#FFE500"; // Tu amarillo yapaso
      toastEmoji.innerText = "🚀";
    } else {
      toastCard.style.backgroundColor = "#FF6B6B"; // Un rojo vibrante que pegue
      toastEmoji.innerText = "⚠️";
    }

    // Animación de entrada
    toastContainer.classList.remove("translate-y-20", "opacity-0");
    toastContainer.classList.add("translate-y-0", "opacity-100");

    // Desaparece solo a los 4 segundos
    setTimeout(() => {
      toastContainer.classList.add("translate-y-20", "opacity-0");
      toastContainer.classList.remove("translate-y-0", "opacity-100");
    }, 4000);
  };

  const checkInputs = () => {
    let allFilled = true;
    inputs?.forEach((input) => {
      const el = input as HTMLInputElement | HTMLTextAreaElement;
      if (el.required && !el.value.trim()) {
        allFilled = false;
      }
    });
    if (btn) btn.disabled = !allFilled;
  };

  inputs?.forEach((input) => {
    input.addEventListener("input", checkInputs);
  });

  checkInputs();

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    btn.disabled = true;
    const originalText = btn.innerText;
    btn.innerText = "Enviando...";

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    try {
      const API_URL = "https://api.yapaso.app/api/contact/send";
      const response = await fetch(API_URL, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });

      if (response.ok) {
        showToast("¡Mensaje enviado! Te respondemos al toque.");
        form.reset();
        checkInputs();
      } else {
        throw new Error();
      }
    } catch (err) {
      showToast("Uh, falló el envío. Probá de nuevo.", "error");
    } finally {
      btn.disabled = false;
      btn.innerText = originalText;
    }
  });
</script>

<style>
  input:not(:placeholder-shown):invalid,
  textarea:not(:placeholder-shown):invalid {
    border-color: #fca5a5;
  }
</style>
