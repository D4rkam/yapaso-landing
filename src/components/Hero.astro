---
// src/components/Hero.astro
import { Image } from "astro:assets";
import phoneMockup from "../assets/hero-phone.webp";
import bolsaCarton from "../assets/bolsa_carton.webp";
---

<section
  class="relative bg-white pt-10 pb-20 md:pt-16 md:pb-32 overflow-hidden"
>
  <div
    class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-12 items-center h-full"
  >
    <div
      class="text-center md:text-left z-30 flex flex-col items-center md:items-start"
    >
      <div class="flex items-center gap-2.5 mb-5">
        <div class="w-3 h-3 rounded-full bg-yapaso-yellow"></div>
        <svg
          class="w-6 h-6 text-yapaso-yellow"
          viewBox="0 0 24 24"
          fill="currentColor"
        >
          <path
            d="M12 0C12 6 18 12 24 12C18 12 12 18 12 24C12 18 6 12 0 12C6 12 12 6 12 0Z"
          ></path>
        </svg>
      </div>

      <h1
        class="font-lobster text-[3.8rem] md:text-[5.5rem] lg:text-[6.5rem] text-yapaso-dark leading-[1.05] tracking-wide drop-shadow-sm"
      >
        Comprá en el buffet <br />
        sin hacer fila
      </h1>

      <p
        class="mt-8 text-xl md:text-2xl text-yapaso-dark font-medium max-w-lg leading-relaxed"
      >
        Pedí desde tu celular y <br /> retiralo cuando esté listo
      </p>

      <div class="mt-10">
        <a
          id="hero-cta-button"
          href="https://app.yapaso.app"
          class="inline-block bg-yapaso-yellow text-yapaso-dark font-bold text-xl md:text-2xl px-10 py-5 rounded-full shadow-[0_10px_30px_rgba(255,229,0,0.4)] hover:bg-yapaso-dark hover:text-white hover:scale-105 transition-all duration-300"
        >
          Acceder a la App
        </a>
      </div>
    </div>

    <div
      class="relative flex justify-center items-center mt-16 md:mt-0 w-full min-h-[450px] md:min-h-[500px]"
    >
      <div
        class="absolute top-4 right-2 md:top-10 md:-right-4 z-0 animate-float-delayed scale-75 md:scale-100 origin-top-right"
      >
        <div
          class="bg-yapaso-yellow border-4 border-yapaso-dark rounded-full px-6 py-2 rotate-12"
        >
          <span class="font-lobster text-xl text-yapaso-dark"
            >¡Al toque! ⚡</span
          >
        </div>
      </div>

      <div
        class="absolute bottom-16 left-6 md:bottom-24 md:left-16 z-0 animate-float scale-75 md:scale-100 origin-bottom-left"
      >
        <svg
          class="w-16 h-16 text-[#FFE500] drop-shadow-[4px_4px_0px_rgba(26,26,26,1)] animate-spin-slow"
          viewBox="0 0 24 24"
          fill="currentColor"
        >
          <path
            stroke="#1A1A1A"
            stroke-width="1.5"
            d="M12 0L14.59 9.41L24 12L14.59 14.59L12 24L9.41 14.59L0 12L9.41 9.41L12 0Z"
          ></path>
        </svg>
      </div>

      <div class="relative z-10 animate-float-phone">
        <Image
          src={phoneMockup}
          alt="App Ya Paso"
          class="w-[220px] md:w-[310px] lg:w-[340px] h-auto drop-shadow-[0_25px_35px_rgba(0,0,0,0.2)] hover:scale-[1.02] transition-transform duration-500"
          widths={[340, 540, 720]}
          sizes="(max-width: 720px) 340px, 720px"
          loading="eager"
          fetchpriority="high"
        />
      </div>

      <div
        class="absolute top-[40%] left-4 md:top-1/2 md:left-6 z-20 animate-float-fast scale-75 md:scale-100 origin-left"
      >
        <div
          class="w-16 h-16 bg-white border-2 border-yapaso-dark rounded-full shadow-[4px_4px_0px_0px_rgba(26,26,26,1)] flex items-center justify-center -rotate-12"
        >
          <Image
            src={bolsaCarton}
            width={70}
            height={70}
            loading="lazy"
            decoding="async"
            alt="Bolsa de pedido"
            class="w-10 h-10 object-contain drop-shadow-sm"
          />
        </div>
      </div>

      <div
        class="absolute bottom-20 right-4 md:bottom-32 md:-right-6 z-20 animate-float scale-75 md:scale-100 origin-bottom-right"
      >
        <div
          class="bg-white border-4 border-yapaso-dark rounded-xl p-3 -rotate-6"
        >
          <span class="font-sans font-bold text-yapaso-dark text-sm"
            >Sin filas 🏃‍♂️</span
          >
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const btn = document.getElementById("hero-cta-button") as HTMLAnchorElement;

  if (btn) {
    const userAgent = navigator.userAgent.toLowerCase();
    const isAndroid = /android/i.test(userAgent);

    // Configuramos el botón según el sistema operativo
    if (isAndroid) {
      btn.innerText = "Descargar App";
      btn.href =
        "https://github.com/d4rkam/YaPasoApp/releases/latest/download/app-release.apk";

      // Agregamos el atributo download (ayuda a algunos navegadores)
      btn.setAttribute("download", "YaPaso.apk");

      // --- EL TRUCO DEL FEEDBACK ---
      btn.addEventListener("click", () => {
        const originalText = btn.innerText;
        btn.innerText = "Iniciando descarga... 🚀";

        // Lo volvemos a la normalidad después de unos segundos
        setTimeout(() => {
          btn.innerText = originalText;
        }, 5000);
      });
    } else {
      btn.innerText = "Acceder a la App";
      btn.href = "https://app.yapaso.app";
    }
  }
</script>

<style>
  .animate-float-phone {
    animation: float-phone 5s ease-in-out infinite;
    animation-delay: 1.5s;
    animation-fill-mode: backwards;
  }

  .animate-float {
    animation: float-item 6s ease-in-out infinite;
  }
  .animate-float-delayed {
    animation: float-item 6s ease-in-out 3s infinite;
  }
  .animate-float-fast {
    animation: float-item 4s ease-in-out 1s infinite;
  }
  .animate-spin-slow {
    animation: spin 15s linear infinite;
  }

  @keyframes float-phone {
    0%,
    100% {
      transform: translateY(0px) rotate(0deg);
    }
    50% {
      transform: translateY(-15px) rotate(1.5deg);
    }
  }

  @keyframes float-item {
    0%,
    100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-20px);
    }
  }

  @keyframes spin {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }
</style>
