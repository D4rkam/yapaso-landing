---
// src/pages/index.astro
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Beneficios from "../components/Beneficios.astro";
import ComoFunciona from "../components/ComoFunciona.astro";
import Equipo from "../components/Equipo.astro";
import Contacto from "../components/Contacto.astro";
import Footer from "../components/Footer.astro";

// Datos para el Schema.org (puedes ajustarlos luego)
const appSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "Ya Paso",
  operatingSystem: "Android, iOS, Web",
  applicationCategory: "FoodApplication",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "ARS",
  },
  description:
    "La aplicación definitiva para pedir y pagar en el buffet de tu colegio o facultad sin hacer filas.",
  author: [
    {
      "@type": "Person",
      name: "Agustina",
    },
    {
      "@type": "Person",
      name: "Thomas",
    },
  ],
};
---

<Layout
  title="Ya Paso | El Buffet en tu celular, sin filas"
  description="Pedí tu comida en el buffet desde el aula y retirá sin esperar. La app para estudiantes que le gana tiempo al recreo."
>
  <script
    type="application/ld+json"
    slot="head"
    set:html={JSON.stringify(appSchema)}
  />

  <Header />

  <main>
    <Hero />

    <Beneficios />
    <ComoFunciona />
    <!-- <Equipo /> -->
    <Contacto />
    <Footer />
  </main>
</Layout>
